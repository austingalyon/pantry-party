# Convex environment variables
# Set these on the Convex dashboard (npx convex dashboard) under Settings > Environment Variables

# Clerk JWT issuer domain (from your Clerk "convex" JWT template)
CLERK_JWT_ISSUER_DOMAIN=https://your-clerk-instance.clerk.accounts.dev/

# OpenAI API key for recipe generation
OPENAI_API_KEY=sk-...

# Anthropic API key for Claude recipe generation
ANTHROPIC_API_KEY=sk-ant-...

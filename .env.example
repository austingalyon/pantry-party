# Environment variables

# Convex deployment (generated when you run `npx convex dev`)
CONVEX_DEPLOYMENT=
CONVEX_URL=

# Public URL for client-side Convex (must have PUBLIC_ prefix for Astro)
PUBLIC_CONVEX_URL=

# OpenAI API key for recipe generation
OPENAI_API_KEY=

# Clerk JWT issuer domain (from your Convex "convex" JWT template settings)
CLERK_JWT_ISSUER_DOMAIN=https://your-clerk-instance.clerk.accounts.dev/

# Optional
DEEPGRAM_API_KEY=

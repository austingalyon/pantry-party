# Environment variables (Astro frontend)

# Convex deployment (generated when you run `npx convex dev`)
CONVEX_DEPLOYMENT=
CONVEX_URL=

# Public URL for client-side Convex (must have PUBLIC_ prefix for Astro)
PUBLIC_CONVEX_URL=

# Clerk publishable key (from Clerk dashboard)
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Optional
DEEPGRAM_API_KEY=

# Note: Convex backend env vars (OPENAI_API_KEY, CLERK_JWT_ISSUER_DOMAIN)
# are set on the Convex dashboard, not here. See convex/.env.example.
